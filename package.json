{
  "name": "babel-letiende",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:babel-letiende": "node dist/babel-letiende/server/server.mjs",
    "build:api": "tsc -p server/tsconfig.json",
    "build:infra": "npm run build && npm run build:api",
    "package:staging": "npm run build:infra && npx serverless package --stage staging",
    "deploy:staging": "npm run build:infra && npx serverless deploy --stage staging",
    "deploy:production": "npm run build:infra && npx serverless deploy --stage production"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.7",
    "@aws-sdk/client-dynamodb": "^3.1090.0",
    "@aws-sdk/lib-dynamodb": "^3.1090.0",
    "@codegenie/serverless-express": "^5.0.0",
    "express": "^5.1.0",
    "firebase": "^12.16.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/aws-lambda": "8.10.162",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.19",
    "prettier": "^3.8.1",
    "serverless": "4.39.0",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
